{
  "name": "dimension-creation-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-age-data.mjs",
    "dev": "vite",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc -b",
    "build": "node scripts/build-age-data.mjs && tsc -b && vite build && node scripts/create-sites-worker.mjs && node scripts/prune-dist.mjs",
    "preview": "vite preview",
    "sync:age": "node scripts/sync-age.mjs --all-categories",
    "sync:age:full": "node scripts/sync-age.mjs --all-categories --details --play",
    "build:age-data": "node scripts/build-age-data.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.1.5"
  }
}
